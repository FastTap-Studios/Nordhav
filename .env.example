# Public frontend config (also committed as .env.production for Cloudflare Git builds)
VITE_SUPABASE_URL="https://torqcelofqtpfdvktdua.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-from-supabase-dashboard"

# GEMINI_API_KEY: Required for Gemini AI API calls (Render/Docker only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL of the deployed app (Stripe redirects, etc.)
# Local: http://localhost:3000
# Cloudflare Pages: https://nordhav.pages.dev (or your custom domain)
# Render: https://nordhav.onrender.com
APP_URL="https://nordhav.pages.dev"

# STRIPE_SECRET_KEY: Needed for server-side payments (Render/Docker only).
STRIPE_SECRET_KEY="sk_test_..."

# VITE_STRIPE_PUBLIC_KEY: Needed for client-side checkout.
VITE_STRIPE_PUBLIC_KEY="pk_test_..."

# --- Supabase Auth (Dashboard → Authentication → URL Configuration) ---
# Site URL: same as APP_URL in production
# Redirect URLs: add your production URL, e.g. https://nordhav.pages.dev/**
