{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A fishing product available in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "integer" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "imageUrl", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "items": { 
          "type": "array",
          "items": { "type": "object" }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "returned"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "object" },
        "vatAmount": { "type": "number" },
        "shippingCost": { "type": "number" }
      },
      "required": ["email", "items", "totalAmount", "status", "createdAt"]
    },
    "UserSettings": {
      "title": "User Settings",
      "description": "User specific data and roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "StoreSettings": {
      "title": "Store Settings",
      "description": "Global settings for the store.",
      "type": "object",
      "properties": {
        "vatRate": { "type": "number" },
        "baseShippingCost": { "type": "number" },
        "freeShippingThreshold": { "type": "number" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Product catalog."
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "users": {
      "schema": "UserSettings",
      "description": "User profiles and roles."
    },
    "settings": {
      "schema": "StoreSettings",
      "description": "Global store configuration."
    }
  }
}
